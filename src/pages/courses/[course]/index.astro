---
import CourseLayout from '../../../layouts/CourseLayout.astro';
import { getCollection } from 'astro:content';
import { fetchSchedule } from '../../../utils/parseSchedule';
import { mdInline } from '../../../utils/helpers';
import { flattenResources } from '../../../utils/resources';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const courses = await getCollection('courses');
  return courses.map(course => ({
    params: { course: course.slug },
    props: { course },
  }));
};

const { course } = Astro.props;
const { Content } = await course.render();

// --- Schedule-first mode ---
interface ScheduleDef {
  id: string;
  label: string;
  url: string;
}

const scheduleDefs: ScheduleDef[] =
  course.data.schedules && course.data.schedules.length > 0
    ? course.data.schedules
    : course.data.scheduleUrl
      ? [{ id: 'default', label: 'Cronograma', url: course.data.scheduleUrl }]
      : [];

const hasSchedule = scheduleDefs.length > 0;

// Load all resources for this course
const rawResources = await getCollection('resources', ({ data }) => data.course === course.slug);
const allResources = flattenResources(rawResources);

// General resources (no class) → collapsible section
const generalResources = allResources
  .filter(r => r.data.class == null)
  .sort((a, b) => a.data.order - b.data.order);

// ── Rowspan pre-processing ──────────────────────────────────────────────────
type Column = 'materiais' | 'exercicios' | 'extra';

function defaultColumn(type: string): Column {
  if (['slides', 'pdf', 'link'].includes(type)) return 'materiais';
  return 'extra';
}

function parseClassRange(val: string | number): { from: number; to: number } {
  const s = String(val);
  const parts = s.split('-').map(p => parseInt(p.trim(), 10));
  if (parts.length === 2 && !isNaN(parts[0]) && !isNaN(parts[1])) {
    return { from: Math.min(parts[0], parts[1]), to: Math.max(parts[0], parts[1]) };
  }
  const n = parseInt(s, 10);
  return { from: n, to: n };
}

interface ClassPoint {
  classNumber: number;
  rowIndex: number;
}

interface CellData {
  resources: typeof allResources;
  rowspan: number;
  skip: boolean;
}

function rangePoints(from: number, to: number, rowIndexByClass: Map<number, number>): ClassPoint[] {
  const points: ClassPoint[] = [];
  for (let c = from; c <= to; c++) {
    const rowIndex = rowIndexByClass.get(c);
    if (rowIndex != null) points.push({ classNumber: c, rowIndex });
  }
  return points;
}

function splitIntoContiguousSegments(points: ClassPoint[]): ClassPoint[][] {
  if (points.length === 0) return [];
  const segments: ClassPoint[][] = [[points[0]]];

  for (let i = 1; i < points.length; i++) {
    const prev = points[i - 1];
    const curr = points[i];
    const contiguousByClass = curr.classNumber === prev.classNumber + 1;
    const contiguousByRow = curr.rowIndex === prev.rowIndex + 1;

    if (contiguousByClass && contiguousByRow) {
      segments[segments.length - 1].push(curr);
    } else {
      segments.push([curr]);
    }
  }

  return segments;
}

function buildCellMap(scheduleEntries: Awaited<ReturnType<typeof fetchSchedule>>['entries']): Map<string, CellData> {
  const cellMap = new Map<string, CellData>();
  const rowIndexByClass = new Map<number, number>();

  scheduleEntries.forEach((entry, idx) => {
    if (entry.number != null && !rowIndexByClass.has(entry.number)) {
      rowIndexByClass.set(entry.number, idx);
    }
  });

  for (const r of allResources) {
    if (r.data.class == null) continue;
    const col: Column = (r.data.column as Column | undefined) ?? defaultColumn(r.data.type);
    const { from, to } = parseClassRange(r.data.class as string | number);
    const segments = splitIntoContiguousSegments(rangePoints(from, to, rowIndexByClass));
    if (segments.length === 0) continue;

    for (const segment of segments) {
      const startClass = segment[0].classNumber;
      const span = segment.length;
      const startKey = `${startClass}:${col}`;

      if (!cellMap.has(startKey)) {
        cellMap.set(startKey, { resources: [], rowspan: span, skip: false });
      }
      const cell = cellMap.get(startKey)!;
      cell.resources.push(r);
      cell.rowspan = Math.max(cell.rowspan, span);

      for (let i = 1; i < segment.length; i++) {
        const skipKey = `${segment[i].classNumber}:${col}`;
        if (!cellMap.has(skipKey)) {
          cellMap.set(skipKey, { resources: [], rowspan: 1, skip: true });
        }
      }
    }
  }

  // Sort resources inside each cell by order
  for (const cell of cellMap.values()) {
    cell.resources.sort((a, b) => a.data.order - b.data.order);
  }

  return cellMap;
}

interface ScheduleView {
  id: string;
  label: string;
  entries: Awaited<ReturnType<typeof fetchSchedule>>['entries'];
  defaultRoom: string;
  cellMap: Map<string, CellData>;
}

const scheduleViews: ScheduleView[] = [];
for (const def of scheduleDefs) {
  const result = await fetchSchedule(def.url);
  scheduleViews.push({
    id: def.id,
    label: def.label,
    entries: result.entries,
    defaultRoom: result.defaultRoom,
    cellMap: buildCellMap(result.entries),
  });
}

// Group general resources by type (for the collapsible Recursos section)
const generalResourcesByType: Record<string, typeof generalResources> = {};
for (const r of generalResources) {
  if (!generalResourcesByType[r.data.type]) generalResourcesByType[r.data.type] = [];
  generalResourcesByType[r.data.type].push(r);
}

// ── Helpers ─────────────────────────────────────────────────────────────────
function activityClass(activity: string, description: string): string {
  const a = activity.toLowerCase();
  const d = description.toLowerCase();
  if (a.includes('g2'))                                          return 'activity-g2';
  if (a.includes('substituição') || a.includes('substituicao')) return 'activity-sub';
  if (a.includes('prova') || a.includes('exame'))               return 'activity-exam';
  if (a.includes('trabalho'))                                    return 'activity-trabalho';
  if (a.includes('feriado') || d.includes('feriado'))           return 'activity-feriado';
  if (a.includes('evento') || a.includes('acadêmico') || a.includes('academico')) return 'activity-evento';
  return 'activity-class';
}

function parseBrDate(date: string): Date | null {
  const [dayStr, monthStr, yearStr] = date.split('/');
  const day = Number(dayStr);
  const month = Number(monthStr);
  const year = Number(yearStr);
  if (!day || !month || !year) return null;
  const parsed = new Date(year, month - 1, day);
  if (
    parsed.getFullYear() !== year ||
    parsed.getMonth() !== month - 1 ||
    parsed.getDate() !== day
  ) return null;
  return parsed;
}

function easterSunday(year: number): Date {
  // Meeus/Jones/Butcher Gregorian algorithm.
  const a = year % 19;
  const b = Math.floor(year / 100);
  const c = year % 100;
  const d = Math.floor(b / 4);
  const e = b % 4;
  const f = Math.floor((b + 8) / 25);
  const g = Math.floor((b - f + 1) / 3);
  const h = (19 * a + b - d - g + 15) % 30;
  const i = Math.floor(c / 4);
  const k = c % 4;
  const l = (32 + 2 * e + 2 * i - h - k) % 7;
  const m = Math.floor((a + 11 * h + 22 * l) / 451);
  const month = Math.floor((h + l - 7 * m + 114) / 31);
  const day = ((h + l - 7 * m + 114) % 31) + 1;
  return new Date(year, month - 1, day);
}

function addDays(date: Date, days: number): Date {
  const copy = new Date(date);
  copy.setDate(copy.getDate() + days);
  return copy;
}

function sameDate(a: Date, b: Date): boolean {
  return a.getFullYear() === b.getFullYear() &&
    a.getMonth() === b.getMonth() &&
    a.getDate() === b.getDate();
}

function holidayReasonByDate(date: string): string {
  const d = parseBrDate(date);
  if (!d) return '';

  const mmdd = `${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  const fixedHolidays: Record<string, string> = {
    '01-01': 'Confraternização Universal',
    '04-21': 'Tiradentes',
    '05-01': 'Dia do Trabalho',
    '09-07': 'Independência do Brasil',
    '10-12': 'Nossa Senhora Aparecida',
    '11-02': 'Finados',
    '11-15': 'Proclamação da República',
    '11-20': 'Dia da Consciência Negra',
    '12-25': 'Natal',
  };
  if (fixedHolidays[mmdd]) return fixedHolidays[mmdd];

  const easter = easterSunday(d.getFullYear());
  if (sameDate(d, addDays(easter, -48))) return 'Carnaval';
  if (sameDate(d, addDays(easter, -47))) return 'Carnaval';
  if (sameDate(d, addDays(easter, -2))) return 'Paixão de Cristo';
  if (sameDate(d, easter)) return 'Páscoa';
  if (sameDate(d, addDays(easter, 60))) return 'Corpus Christi';

  return '';
}

function activityBadgeLabel(activityClassName: string, activity: string, description: string, date: string): string {
  if (activityClassName === 'activity-feriado') {
    const reasonFromDescription = description
      .replace(/^feriado\s*[-:]?\s*/i, '')
      .trim();
    const reason = reasonFromDescription && !/^feriado$/i.test(reasonFromDescription)
      ? reasonFromDescription
      : holidayReasonByDate(date);
    return reason ? `Feriado - ${reason}` : 'Feriado';
  }
  return activity;
}

function dayLabel(abbr: string): string {
  const map: Record<string, string> = {
    SEG: 'Seg', TER: 'Ter', QUA: 'Qua', QUI: 'Qui',
    SEX: 'Sex', SAB: 'Sáb', DOM: 'Dom',
  };
  return map[abbr.toUpperCase()] ?? abbr;
}

function shortDate(date: string): string {
  const parts = date.split('/');
  return parts.length >= 2 ? `${parts[0]}/${parts[1]}` : date;
}

function shortRoomLabel(room: string): string {
  return room.replace(/\bLaborat[oó]rio\b/gi, 'Lab');
}

function resourceHref(r: (typeof allResources)[number]): string {
  return r.data.pdfPath ?? r.data.url ?? '#';
}

const COLUMNS: Column[] = ['materiais', 'exercicios', 'extra'];
const COL_LABELS: Record<Column, string> = {
  materiais: 'Materiais',
  exercicios: 'Exercícios',
  extra: 'Extra',
};

// Type label mapping for resource types
const typeLabels: Record<string, string> = {
  book: 'Livros', tool: 'Ferramentas', link: 'Links',
  video: 'Vídeos', slides: 'Slides', pdf: 'PDFs', other: 'Outros',
};
---

<CourseLayout
  title={course.data.title}
  courseSlug={course.slug}
  courseTitle={course.data.title}
  courseColor={course.data.color}
  currentSection="overview"
  description={course.data.description}
>
  <h1>{course.data.title}</h1>
  <p class="course-subtitle">
    <span class="course-badge" style={`background: ${course.data.color}`}>{course.data.shortName}</span>
    {course.data.semester}
  </p>

  {hasSchedule ? (
    <div class="schedule-view">

      {course.data.objectives && course.data.objectives.length > 0 && (
        <details class="collapsible-section">
          <summary>Objetivos da disciplina</summary>
          <ul>{course.data.objectives.map(obj => <li>{obj}</li>)}</ul>
        </details>
      )}

      {course.data.bibliography && course.data.bibliography.length > 0 && (
        <details class="collapsible-section">
          <summary>Bibliografia</summary>
          <ul>{course.data.bibliography.map(b => <li set:html={mdInline(b)} />)}</ul>
        </details>
      )}

      {generalResources.length > 0 && (
        <details class="collapsible-section">
          <summary>Recursos</summary>
          {Object.entries(generalResourcesByType).map(([type, items]) => (
            <div class="resource-group">
              <h4>{typeLabels[type] ?? type}</h4>
              <ul>
                {items.map(r => {
                  const href = r.data.pdfPath ?? r.data.url;
                  return (
                    <li>
                      {href
                        ? <a href={href} target="_blank" rel="noopener">{r.data.title}</a>
                        : r.data.title}
                      {r.data.description && <span class="res-desc"> — {r.data.description}</span>}
                    </li>
                  );
                })}
              </ul>
            </div>
          ))}
        </details>
      )}

      {scheduleViews.length > 1 && (
        <div class="schedule-toolbar">
          <label for="schedule-select">Turma</label>
          <select id="schedule-select" class="schedule-select">
            {scheduleViews.map(schedule => (
              <option value={schedule.id}>{schedule.label}</option>
            ))}
          </select>
        </div>
      )}

      <div class="schedule-panels" data-schedule-root data-course-slug={course.slug}>
        {scheduleViews.map((schedule, idx) => (
          <section class="schedule-panel" data-schedule-id={schedule.id} hidden={idx !== 0}>
            {schedule.entries.length === 0 ? (
              <div class="schedule-unavailable">
                <p>Cronograma não disponível no momento.</p>
              </div>
            ) : (
              <div class="schedule-table-wrapper">
                <table class="schedule-table">
                  <thead>
                    <tr>
                      <th class="col-num">#</th>
                      <th class="col-date">Data</th>
                      <th class="col-topic">Tópico</th>
                      <th class="col-room">Sala</th>
                      {COLUMNS.map(col => <th class={`col-${col}`}>{COL_LABELS[col]}</th>)}
                    </tr>
                  </thead>
                  <tbody>
                    {schedule.entries.map(entry => {
                      const room = shortRoomLabel(entry.resources || schedule.defaultRoom || '—');
                      const aClass = activityClass(entry.activity, entry.description);
                      return (
                        <tr
                          class={`schedule-row ${aClass}`}
                          data-class-number={entry.number ?? undefined}
                          data-class-date={entry.date}
                        >
                          <td class="col-num">{entry.number ?? '—'}</td>
                          <td class="col-date">
                            <span class="date-day">{dayLabel(entry.day)}</span>
                            <span class="date-num">{shortDate(entry.date)}</span>
                          </td>
                          <td class="col-topic">
                            <span class="topic-text">{entry.description || '—'}</span>
                            {aClass !== 'activity-class' && (
                              <span class={`activity-badge ${aClass}`}>{activityBadgeLabel(aClass, entry.activity, entry.description, entry.date)}</span>
                            )}
                          </td>
                          <td class="col-room">{room}</td>
                          {COLUMNS.map(col => {
                            const key = `${entry.number}:${col}`;
                            const cell = schedule.cellMap.get(key) ?? { resources: [], rowspan: 1, skip: false };
                            if (cell.skip) return null;
                            return (
                              <td
                                rowspan={cell.rowspan > 1 ? cell.rowspan : undefined}
                                class={`col-${col}`}
                                data-span-start={cell.rowspan > 1 ? entry.number ?? undefined : undefined}
                                data-span-end={cell.rowspan > 1 && entry.number != null ? entry.number + cell.rowspan - 1 : undefined}
                              >
                                {cell.resources.length > 0 && (
                                  <div class="material-links">
                                    {cell.resources.map(r => (
                                      <a
                                        href={resourceHref(r)}
                                        class={`material-link type-${r.data.type}`}
                                        target="_blank"
                                        rel="noopener"
                                      >
                                        {r.data.title}
                                      </a>
                                    ))}
                                  </div>
                                )}
                              </td>
                            );
                          })}
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            )}
          </section>
        ))}
      </div>
    </div>
  ) : (
    <div>
      {course.data.objectives && course.data.objectives.length > 0 && (
        <section class="overview-section">
          <h2>Objetivos</h2>
          <ul>{course.data.objectives.map(obj => <li>{obj}</li>)}</ul>
        </section>
      )}
      {course.data.bibliography && course.data.bibliography.length > 0 && (
        <section class="overview-section">
          <h2>Bibliografia</h2>
          <ul>{course.data.bibliography.map(book => <li set:html={mdInline(book)} />)}</ul>
        </section>
      )}
      <section class="overview-section prose">
        <Content />
      </section>
    </div>
  )}
</CourseLayout>

<script>
  const initScheduleEnhancements = () => {
    const root = document.querySelector('[data-schedule-root]');
    if (!root) return;
    if (root.getAttribute('data-enhanced') === '1') return;
    root.setAttribute('data-enhanced', '1');

    const panels = Array.from(root.querySelectorAll('.schedule-panel'));
    const selector = document.getElementById('schedule-select');
    const courseSlug = root.getAttribute('data-course-slug') || 'default';
    const storageKey = `course-schedule:${courseSlug}`;
    const validIds = new Set(panels.map(panel => panel.getAttribute('data-schedule-id')).filter(Boolean));

    const getUrlScheduleId = () => {
      const params = new URLSearchParams(window.location.search);
      const fromTurma = params.get('turma');
      const fromSchedule = params.get('schedule');
      const candidate = fromTurma || fromSchedule;
      return candidate && validIds.has(candidate) ? candidate : null;
    };

    const setUrlScheduleId = scheduleId => {
      const url = new URL(window.location.href);
      url.searchParams.set('turma', scheduleId);
      url.searchParams.delete('schedule');
      window.history.replaceState({}, '', url);
    };

    const showPanel = scheduleId => {
      for (const panel of panels) {
        const isVisible = panel.getAttribute('data-schedule-id') === scheduleId;
        panel.hidden = !isVisible;
      }
    };

    if (panels.length > 0) {
      let activeId = panels[0].getAttribute('data-schedule-id');
      const urlScheduleId = getUrlScheduleId();
      if (urlScheduleId) activeId = urlScheduleId;

      if (selector) {
        if (!urlScheduleId) {
          try {
            const savedId = localStorage.getItem(storageKey);
            if (savedId && validIds.has(savedId)) {
              activeId = savedId;
            }
          } catch {
            // ignore storage errors (private browsing / restricted mode)
          }
        }

        if (activeId) selector.value = activeId;
        selector.addEventListener('change', () => {
          const selectedId = selector.value;
          showPanel(selectedId);
          setUrlScheduleId(selectedId);
          try {
            localStorage.setItem(storageKey, selectedId);
          } catch {
            // ignore storage errors (private browsing / restricted mode)
          }
        });
      }

      if (activeId) {
        showPanel(activeId);
        setUrlScheduleId(activeId);
      }
    }

    const parseBrDate = value => {
      const normalized = String(value || '').trim();
      const match = normalized.match(/^(\d{1,2})\/(\d{1,2})(?:\/(\d{2}|\d{4}))?$/);
      if (!match) return null;
      const day = Number(match[1]);
      const month = Number(match[2]);
      let year = new Date().getFullYear();
      if (match[3]) {
        const parsedYear = Number(match[3]);
        year = match[3].length === 2 ? 2000 + parsedYear : parsedYear;
      }
      const date = new Date(year, month - 1, day);
      if (
        date.getFullYear() !== year ||
        date.getMonth() !== month - 1 ||
        date.getDate() !== day
      ) return null;
      date.setHours(0, 0, 0, 0);
      return date;
    };

    const highlightNextClass = panel => {
      const rows = Array.from(panel.querySelectorAll('tbody .schedule-row'));
      for (const row of rows) row.classList.remove('schedule-next-row');
      if (rows.length === 0) return null;

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      let selectedRow = null;
      let selectedDate = null;

      for (const row of rows) {
        const rawDate = row.getAttribute('data-class-date');
        const classDate = parseBrDate(rawDate);
        if (!classDate || classDate < today) continue;
        if (!selectedDate || classDate < selectedDate) {
          selectedDate = classDate;
          selectedRow = row;
        }
      }

      if (selectedRow) selectedRow.classList.add('schedule-next-row');
      return selectedDate;
    };

    const applyMaterialWindow = (panel, nextDate) => {
      const rows = Array.from(panel.querySelectorAll('tbody .schedule-row'));
      for (const row of rows) row.classList.remove('schedule-future-locked');

      if (!nextDate) return;

      for (const row of rows) {
        const rawDate = row.getAttribute('data-class-date');
        const classDate = parseBrDate(rawDate);
        if (!classDate) continue;
        if (classDate > nextDate) row.classList.add('schedule-future-locked');
      }
    };

    for (const panel of panels) {
      const nextDate = highlightNextClass(panel);
      applyMaterialWindow(panel, nextDate);
    }

    const tables = Array.from(root.querySelectorAll('.schedule-table'));
    for (const table of tables) {
      const bodyRows = Array.from(table.querySelectorAll('tbody tr'));
      const spanCells = Array.from(table.querySelectorAll('td[data-span-start][data-span-end]'));
      let activeCells = [];

      const clearHover = () => {
        for (const cell of activeCells) cell.classList.remove('rowspan-hover');
        activeCells = [];
      };

      const applyHoverForRow = row => {
        clearHover();
        const classNumber = Number(row.dataset.classNumber);
        if (!Number.isFinite(classNumber)) return;

        for (const cell of spanCells) {
          const start = Number(cell.dataset.spanStart);
          const end = Number(cell.dataset.spanEnd);
          if (Number.isFinite(start) && Number.isFinite(end) && classNumber >= start && classNumber <= end) {
            cell.classList.add('rowspan-hover');
            activeCells.push(cell);
          }
        }
      };

      for (const row of bodyRows) {
        row.addEventListener('mouseenter', () => applyHoverForRow(row));
        row.addEventListener('mouseleave', clearHover);
      }
    }
  };

  initScheduleEnhancements();
  document.addEventListener('DOMContentLoaded', initScheduleEnhancements);
  document.addEventListener('astro:after-swap', initScheduleEnhancements);
</script>

<style>
  .course-subtitle {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
  }

  .course-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: 700;
    color: #fff;
    border-radius: var(--radius-sm);
  }

  /* ── Overview layout ─────────────────────────────────────────────────── */
  .overview-section { margin-bottom: var(--space-8); }
  .overview-section h2 { border-top: none; margin-top: 0; padding-top: 0; }

  /* ── Collapsible sections ────────────────────────────────────────────── */
  .collapsible-section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-3);
    padding: var(--space-3) var(--space-4);
  }

  .collapsible-section summary {
    cursor: pointer;
    font-weight: 600;
    list-style: none;
    color: var(--color-text);
    user-select: none;
  }

  .collapsible-section summary::-webkit-details-marker { display: none; }
  .collapsible-section summary::before { content: '▸ '; color: var(--color-text-muted); }
  .collapsible-section[open] summary::before { content: '▾ '; }

  .collapsible-section ul { margin: var(--space-3) 0 0 var(--space-4); padding: 0; }

  .resource-group { margin-top: var(--space-3); }
  .resource-group h4 {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-1);
  }
  .res-desc { color: var(--color-text-secondary); font-size: var(--font-size-sm); }

  .schedule-toolbar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .schedule-toolbar label {
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .schedule-select {
    min-width: 14rem;
    padding: var(--space-1) var(--space-2);
    border: 1px solid var(--color-border);
